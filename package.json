    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@types/node": "^24.0.10",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.1.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.12",
    "wrangler": "^4.105.0"
  }
}
